# ============================================================
# PRODUCTION environment template — copy to .env and fill in
# ============================================================

# Application
APP_NAME="DocuLume API"
APP_VERSION="2.0.0"
ENVIRONMENT="production"
DEBUG=false
API_V1_PREFIX="/api/v1"

# Database — must NOT be localhost
# Format: postgresql+asyncpg://user:password@host:5432/dbname
DATABASE_URL="postgresql+asyncpg://doculume_user:CHANGE_ME@db.your-domain.com:5432/doculume_prod"
DB_ECHO=false
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
DB_POOL_RECYCLE=3600

# Redis — must include password
# Format: redis://:password@host:6379/0
REDIS_URL="redis://:CHANGE_ME@redis.your-domain.com:6379/0"
REDIS_PASSWORD="CHANGE_ME"
REDIS_CACHE_TTL=3600

# Celery
CELERY_BROKER_URL="redis://:CHANGE_ME@redis.your-domain.com:6379/1"
CELERY_RESULT_BACKEND="redis://:CHANGE_ME@redis.your-domain.com:6379/2"

# Authentication
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY="CHANGE_ME_64_hex_chars"
JWT_ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Encryption
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY="CHANGE_ME"

# OAuth2 (optional)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""
OAUTH_REDIRECT_URL="https://app.your-domain.com/auth/callback"

# LLM Providers (at least one required)
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""
GOOGLE_API_KEY=""
DEFAULT_LLM_PROVIDER="openai"
DEFAULT_LLM_MODEL="gpt-4o-mini"

# Document Processing
STORAGE_PATH="/app/storage"
MAX_FILE_SIZE_MB=50
ALLOWED_FILE_TYPES=[".pdf",".txt",".docx",".md"]
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# Vector Database
CHROMA_PERSIST_DIRECTORY="/app/chroma_data"
EMBEDDING_MODEL="text-embedding-ada-002"
RETRIEVAL_TOP_K=5

# Security — set to your actual frontend domain(s)
CORS_ORIGINS=["https://app.your-domain.com","https://admin.your-domain.com"]
RATE_LIMIT_PER_MINUTE=60

# Monitoring
LOG_LEVEL="INFO"
LOG_FORMAT="json"
OTEL_ENABLED=false

# Error tracking (get DSN from sentry.io)
SENTRY_DSN=""

# Monitoring (only needed when running with --profile monitoring)
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD="CHANGE_ME"
